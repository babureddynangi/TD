    "record_id",
    "account_id",
    "tradeline_id",
    "product_type",
    "state_code",
    "zip_code",
    "reporting_date",
    "account_status",
    "payment_status",
    "current_balance",
    "credit_limit",
    "available_credit",
    "past_due_amount",
